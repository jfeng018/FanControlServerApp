#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/logs/script.log"
PID_FILE="${TRIM_PKGVAR}/run/app.pid"
SERVER_BIN="${TRIM_APPDEST}/server/fancontrolserver"

# 确保日志目录存在
mkdir -p "$(dirname "$LOG_FILE")"
# 确保运行时状态目录存在
mkdir -p "$(dirname "$PID_FILE")"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

start_process() {
    if status; then
        return 0
    fi

    if [ ! -f "${SERVER_BIN}" ]; then
        log_msg "Server binary not found: ${SERVER_BIN}"
        if [ -n "${TRIM_TEMP_LOGFILE}" ]; then
            printf "%s\n" "Server binary not found: ${SERVER_BIN}" > "${TRIM_TEMP_LOGFILE}"
        fi
        return 1
    fi

    if [ ! -x "${SERVER_BIN}" ]; then
        chmod +x "${SERVER_BIN}" 2>/dev/null
    fi

    log_msg "Starting process ..."
    log_msg "Server binary path: ${SERVER_BIN}"
    # 直接运行二进制，不重定向输出（程序输出将显示在终端）
    "${SERVER_BIN}" &
    printf "%s" "$!" > "${PID_FILE}"
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file 1"
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM "${pid}" 2>/dev/null

        local count=0
        while check_process "${pid}" && [ "${count}" -lt 10 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}" 2>/dev/null
            sleep 1
        fi

        rm -f "${PID_FILE}"
        log_msg "process stopped, pid file removed"
    fi

    return 0
}

check_process() {
    local pid="$1"
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case "$1" in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac